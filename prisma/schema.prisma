generator client {
  provider = "prisma-client"
  output   = "./generated"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String  @id @default(uuid())
  email     String  @unique
  password  String?
  username  String
  image     String?
  isBlocked Boolean @default(false)
  isDeleted Boolean @default(false)
  role      Role    @default(USER)
  plan      Plan    @default(FREE)

  accounts Account[]
  tokens   Token[]
  files    File[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

model Token {
  id        String    @id @default(uuid())
  token     String
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      TokenType
  expiresIn DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("tokens")
}

model Account {
  id                String @id @default(uuid())
  userId            String
  user              User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider          String
  providerAccountId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model File {
  id        String  @id @default(uuid())
  userId    String
  key       String
  fileName   String
  type      String
  category  String
  size      Int
  isBlocked Boolean @default(false)
  isDeleted Boolean @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@map("files")
}

enum Role {
  USER
  ADMIN
}

enum Plan {
  FREE
  PRO
  PREMIUM
}

enum TokenType {
  VERIFICATION_EMAIL
  RESET_PASSWORD
  DELETE_ACCOUNT
}
